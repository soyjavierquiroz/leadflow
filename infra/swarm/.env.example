# Runtime environment
APP_ENV=staging
APP_BASE_DOMAIN=exitosos.com

# Runtime hosts (used by Traefik Host rules)
LEADFLOW_SITE_HOST=exitosos.com
LEADFLOW_MEMBERS_HOST=members.exitosos.com
LEADFLOW_ADMIN_HOST=admin.exitosos.com
LEADFLOW_API_HOST=api.exitosos.com

# Runtime URLs (used by web/api containers)
SITE_URL=https://exitosos.com
MEMBERS_URL=https://members.exitosos.com
ADMIN_URL=https://admin.exitosos.com
API_URL=https://api.exitosos.com
CORS_ALLOWED_ORIGINS=https://exitosos.com,https://members.exitosos.com,https://admin.exitosos.com

# Shared postgres for staging Swarm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=leadflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_IN_PORTAINER
DATABASE_URL=postgresql://postgres:CHANGE_IN_PORTAINER@postgres:5432/leadflow?schema=public

# Optional replicas
LEADFLOW_WEB_REPLICAS=1
LEADFLOW_API_REPLICAS=1
