# Runtime environment
APP_ENV=staging
APP_BASE_DOMAIN=leadflow.kurukin.com

# Runtime hosts (used by Traefik Host rules)
LEADFLOW_SITE_HOST=leadflow.kurukin.com
LEADFLOW_API_HOST=api.leadflow.kurukin.com
LEADFLOW_SAAS_FALLBACK_HOST=proxy-fallback.leadflow.kurukin.com
LEADFLOW_SAAS_CUSTOMERS_HOST=customers.leadflow.kurukin.com

# Runtime URLs (used by web/api containers)
SITE_URL=https://leadflow.kurukin.com
MEMBERS_URL=https://leadflow.kurukin.com
ADMIN_URL=https://leadflow.kurukin.com
API_URL=https://api.leadflow.kurukin.com
CORS_ALLOWED_ORIGINS=https://leadflow.kurukin.com,https://retodetransformacion.com,https://www.retodetransformacion.com
DATABASE_URL=postgresql://<user>:<password>@<postgres-host>:5432/leadflow?schema=public
EVOLUTION_API_INTERNAL_BASE_URL=http://evolution_api_v2:8080
EVOLUTION_API_KEY=
N8N_WEBHOOK_INTERNAL_BASE=http://n8n-v2_n8n_v2_webhook:5678/webhook
N8N_WEBHOOK_ID=7feee028-e25e-43a3-abac-1a0bf7b0ccf4
N8N_WEBHOOK_SECRET=
N8N_DISPATCHER_WEBHOOK_URL=http://n8n-v2_n8n_v2_webhook:5678/webhook/channels/dispatcher/lead-context-upsert
N8N_DISPATCHER_API_KEY=
RUNTIME_CONTEXT_CENTRAL_BASE_URL=
RUNTIME_CONTEXT_REGISTER_PATH=/register
RUNTIME_CONTEXT_RESOLVE_FULL_PATH=/resolve-full
RUNTIME_CONTEXT_CENTRAL_API_KEY=
RUNTIME_CONTEXT_REQUEST_TIMEOUT_MS=5000
RUNTIME_CONTEXT_RESOLVE_RETRIES=5
RUNTIME_CONTEXT_RESOLVE_DELAY_MS=1000
MESSAGING_AUTOMATION_WEBHOOK_BASE_URL=http://leadflow_api:3001
N8N_AUTOMATION_WEBHOOK_BASE_URL=
CLOUDFLARE_SAAS_FALLBACK_ORIGIN=proxy-fallback.leadflow.kurukin.com
CLOUDFLARE_SAAS_CUSTOMER_CNAME_TARGET=customers.leadflow.kurukin.com

# Dedicated postgres for Leadflow staging Swarm
POSTGRES_DB=leadflow
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=CHANGE_IN_PORTAINER

# Optional replicas
LEADFLOW_WEB_REPLICAS=1
LEADFLOW_API_REPLICAS=1
