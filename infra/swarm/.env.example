# Runtime environment
APP_ENV=staging
APP_BASE_DOMAIN=leadflow.kuruk.in
NEXT_PUBLIC_APP_URL=https://leadflow.kuruk.in

# Runtime hosts (used by Traefik Host rules)
LEADFLOW_SITE_HOST=leadflow.kuruk.in
LEADFLOW_API_HOST=api.leadflow.kuruk.in
LEADFLOW_SAAS_FALLBACK_HOST=proxy-fallback.leadflow.kuruk.in
LEADFLOW_SAAS_CUSTOMERS_HOST=customers.leadflow.kuruk.in

# Runtime URLs (used by web/api containers)
SITE_URL=https://leadflow.kuruk.in
MEMBERS_URL=https://leadflow.kuruk.in
ADMIN_URL=https://leadflow.kuruk.in
API_URL=https://api.leadflow.kuruk.in
CORS_ALLOWED_ORIGINS=https://leadflow.kuruk.in,https://retodetransformacion.com,https://www.retodetransformacion.com
API_INTERNAL_BASE_URL=http://leadflow_api:3001
# Required in Swarm. Provide the full URL explicitly to avoid broken nested interpolation.
DATABASE_URL=postgresql://<user>:<password>@<postgres-host>:5432/leadflow?schema=public
EVOLUTION_API_INTERNAL_BASE_URL=http://evolution_api_v2:8080
EVOLUTION_API_KEY=
N8N_WEBHOOK_INTERNAL_BASE=http://n8n_v2_webhook:5678/webhook
N8N_WEBHOOK_ID=7feee028-e25e-43a3-abac-1a0bf7b0ccf4
N8N_WEBHOOK_SECRET=
N8N_DISPATCHER_WEBHOOK_URL=http://n8n_v2_webhook:5678/webhook/channels/dispatcher/lead-context-upsert
N8N_DISPATCHER_API_KEY=
N8N_OUTBOUND_WEBHOOK_URL=http://n8n_v2_webhook:5678/webhook/channels/outbound/lead-rescue
IDENTITY_TOKEN_SECRET=change_me_identity_token_secret
IDENTITY_TOKEN_TTL_HOURS=48
YOURLS_API_URL=https://kuruk.in/yourls-api.php
YOURLS_SIGNATURE=
INCOMING_MESSAGING_WEBHOOK_SECRET=
SSO_BLACKLIST_SECRET=leadflow_blacklist_jwt_secret_prod_change_me
KURUKIN_BLACKLIST_API_TOKEN=leadflow_blacklist_admin_key_prod_change_me
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
MAIL_FROM_NAME=Kurukin LeadFlow
MAIL_FROM_ADDRESS=soporte@mail.kurukin.com
MAIL_REPLY_TO_ADDRESS=soporte@kurukin.com
WALLET_ENGINE_BASE_URL=
WALLET_ENGINE_INTERNAL_URL=
WALLET_ENGINE_API_KEY=
RUNTIME_CONTEXT_CENTRAL_BASE_URL=
RUNTIME_CONTEXT_MODE=required
RUNTIME_CONTEXT_REGISTER_PATH=/register
RUNTIME_CONTEXT_RESOLVE_FULL_PATH=/resolve-full
RUNTIME_CONTEXT_CENTRAL_API_KEY=
RUNTIME_CONTEXT_REQUEST_TIMEOUT_MS=5000
RUNTIME_CONTEXT_RESOLVE_RETRIES=5
RUNTIME_CONTEXT_RESOLVE_DELAY_MS=1000
MESSAGING_AUTOMATION_WEBHOOK_BASE_URL=http://leadflow_api:3001
N8N_AUTOMATION_WEBHOOK_BASE_URL=
CLOUDFLARE_SAAS_FALLBACK_ORIGIN=proxy-fallback.leadflow.kuruk.in
CLOUDFLARE_SAAS_CUSTOMER_CNAME_TARGET=customers.leadflow.kuruk.in

# Centralized postgres backing service for Leadflow in the unified cluster
POSTGRES_DB=leadflow
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=CHANGE_IN_PORTAINER

# Optional replicas
LEADFLOW_WEB_REPLICAS=1
LEADFLOW_API_REPLICAS=1
