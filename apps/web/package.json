{
  "name": "@leadflow/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma",
    "predev": "pnpm --filter @leadflow/mail build",
    "prebuild": "pnpm --filter @leadflow/mail build && pnpm run prisma:generate && pnpm --filter kurukin-video-player-pkg build",
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint .",
    "pretypecheck": "pnpm --filter @leadflow/mail build && pnpm run prisma:generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@leadflow/mail": "workspace:*",
    "@codemirror/lang-json": "^6.0.2",
    "@prisma/client": "^6.16.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@uiw/react-codemirror": "^4.25.9",
    "kurukin-video-player-pkg": "workspace:*",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-phone-number-input": "^3.4.16",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "6.16.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
