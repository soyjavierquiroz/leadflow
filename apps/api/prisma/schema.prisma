generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceStatus {
  draft
  active
  archived
}

enum AccountType {
  individual
  microteam
  team
  enterprise
}

enum TeamStatus {
  draft
  pending
  active
  suspended
  archived
}

enum TeamType {
  personal
  commercial_team
  department
}

enum SponsorStatus {
  draft
  active
  paused
  archived
}

enum AvailabilityStatus {
  available
  paused
  offline
}

enum RotationStrategy {
  round_robin
  weighted
  manual
}

enum RotationPoolStatus {
  draft
  active
  archived
}

enum AdWheelStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum TrafficLayer {
  DIRECT
  PAID_WHEEL
  ORGANIC
}

enum FunnelStatus {
  draft
  active
  archived
}

enum DomainStatus {
  draft
  active
  archived
}

enum DomainOnboardingStatus {
  draft
  pending_dns
  pending_validation
  active
  error
}

enum DomainType {
  system_subdomain
  custom_apex
  custom_subdomain
}

enum DomainVerificationStatus {
  unverified
  pending
  verified
  failed
}

enum DomainSslStatus {
  unconfigured
  pending
  active
  failed
}

enum DomainVerificationMethod {
  none
  cname
  txt
  http
}

enum FunnelTemplateStatus {
  draft
  active
  archived
}

enum FunnelInstanceStatus {
  draft
  active
  archived
}

enum FunnelStructuralType {
  generic
  two_step_conversion
  multi_step_conversion
}

enum FunnelStepType {
  landing
  lead_capture
  thank_you
  vsl
  presentation
  qualification
  cta_bridge
  handoff
  confirmation
  redirect
}

enum FunnelPublicationStatus {
  draft
  active
  archived
}

enum FunnelRuntimeHealthStatus {
  healthy
  warning
  broken
}

enum TrackingProvider {
  meta
  tiktok
  custom
}

enum TrackingProfileStatus {
  draft
  active
  archived
}

enum DeduplicationMode {
  browser_server
  browser_only
  server_only
}

enum HandoffStrategyStatus {
  draft
  active
  archived
}

enum HandoffStrategyType {
  immediate_whatsapp
  immediate_internal_assignment
  deferred_queue
  deferred_review
  scheduled_followup
  content_continuation
}

enum LeadSourceChannel {
  manual
  form
  landing_page
  api
  import
  automation
  ORGANIC
  PAID
}

enum VisitorKind {
  anonymous
  identified
}

enum VisitorStatus {
  active
  converted
  archived
}

enum LeadStatus {
  captured
  qualified
  assigned
  nurturing
  won
  lost
}

enum LeadQualificationGrade {
  cold
  warm
  hot
}

enum AssignmentStatus {
  pending
  assigned
  accepted
  reassigned
  closed
}

enum AssignmentReason {
  rotation
  manual
  fallback
  handoff
}

enum CrmAssignmentStatus {
  pending_assignment
  accepted
  auto_accepted
  expired
  reassigned
  closed
}

enum CrmAssignmentSource {
  wheel
  organic
  whatsapp_inbound
  manual
  campaign
  reassignment
}

enum CrmAssignmentEventType {
  assignment_created
  assignment_accepted
  assignment_auto_accepted
  ownership_changed
  assignment_expired
  assignment_reassigned
  conversation_detected
}

enum CrmOutreachStatus {
  queued
  scheduled
  ready
  blocked
  processing
  handed_off
  dispatched
  completed
  failed
  cancelled
}

enum CrmOutreachIntentType {
  initial_contact
  followup
  reactivation
}

enum UserRole {
  SUPER_ADMIN
  TEAM_ADMIN
  MEMBER
}

enum UserStatus {
  active
  disabled
}

enum KnowledgeAuditOperation {
  upload
  delete
}

enum MessagingProvider {
  EVOLUTION
}

enum MessagingConnectionStatus {
  disconnected
  provisioning
  qr_ready
  connecting
  connected
  error
}

enum MessagingRuntimeContextStatus {
  PROVISIONED
  REGISTERED
  READY
}

enum AutomationDispatchStatus {
  pending
  skipped
  dispatched
  failed
}

enum TrackedLinkStatus {
  active
  revoked
  expired
  deleted
}

enum EventActorType {
  system
  user
  visitor
  integration
}

enum EventAggregateType {
  workspace
  team
  sponsor
  rotation_pool
  rotation_member
  funnel
  domain
  funnel_template
  funnel_instance
  funnel_step
  funnel_publication
  tracking_profile
  conversion_event_mapping
  handoff_strategy
  visitor
  lead
  assignment
  event
}

model Workspace {
  id                        String                @id @default(uuid())
  name                      String
  slug                      String                @unique
  status                    WorkspaceStatus
  accountType               AccountType              @default(team)
  timezone                  String
  defaultCurrency           String
  primaryLocale             String
  primaryDomain             String?
  emailNotificationsEnabled Boolean               @default(true)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  teams                     Team[]
  sponsors                  Sponsor[]
  funnels                   Funnel[]
  domains                   Domain[]
  funnelTemplates           FunnelTemplate[]
  funnelInstances           FunnelInstance[]
  funnelSteps               FunnelStep[]
  funnelPublications        FunnelPublication[]
  trackingProfiles          TrackingProfile[]
  handoffStrategies         HandoffStrategy[]
  rotationPools             RotationPool[]
  visitors                  Visitor[]
  leads                     Lead[]
  assignments               Assignment[]
  events                    DomainEvent[]
  funnelEvents              FunnelEvent[]
  users                     User[]
  messagingConnections      MessagingConnection[]
  automationDispatches      AutomationDispatch[]
  trackedLinks              TrackedLink[]
  sponsorVanityShortLinks   SponsorVanityShortLink[]
  leadNotes                 LeadNote[]
  crmLeadAssignments        CrmLeadAssignment[]
  crmAssignmentEvents       CrmAssignmentEvent[]
  crmOutreachQueue          CrmOutreachQueue[]
  commercialProfiles        CommercialProfile[]
}

model Team {
  id                    String                @id @default(uuid())
  workspaceId           String
  name                  String
  code                  String
  logoUrl               String?
  status                TeamStatus
  teamType              TeamType                 @default(commercial_team)
  isActive              Boolean               @default(true)
  lastAssignedUserId    String?
  subscriptionExpiresAt DateTime?
  description           String?
  managerUserId         String?
  maxSeats              Int                   @default(10)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sponsors              Sponsor[]
  funnels               Funnel[]              @relation("TeamDefaultFunnels")
  domains               Domain[]
  funnelInstances       FunnelInstance[]
  funnelSteps           FunnelStep[]
  funnelPublications    FunnelPublication[]
  trackingProfiles      TrackingProfile[]
  handoffStrategies     HandoffStrategy[]
  rotationPools         RotationPool[]
  adWheels              AdWheel[]
  assignments           Assignment[]
  users                 User[]
  messagingConnections  MessagingConnection[]
  aiAgentConfigs        AiAgentConfig[]
  channelInstances      ChannelInstance[]
  automationDispatches  AutomationDispatch[]
  funnelEvents          FunnelEvent[]
  leadNotes             LeadNote[]
  knowledgeAudits       KnowledgeAudit[]
  crmLeadAssignments    CrmLeadAssignment[]
  crmAssignmentEvents   CrmAssignmentEvent[]
  crmOutreachQueue      CrmOutreachQueue[]
  vanityShortLinks      SponsorVanityShortLink[]
  commercialProfile     CommercialProfile?

  @@unique([workspaceId, code])
}

model Sponsor {
  id                              String               @id @default(uuid())
  workspaceId                     String
  teamId                          String
  displayName                     String
  publicSlug                      String?              @unique
  status                          SponsorStatus
  isActive                        Boolean              @default(false)
  avatarUrl                       String?
  email                           String?
  phone                           String?
  availabilityStatus              AvailabilityStatus
  routingWeight                   Int
  memberPortalEnabled             Boolean
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime             @updatedAt
  workspace                       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                            Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  rotationMembers                 RotationMember[]
  adWheelParticipants             AdWheelParticipant[]
  adWheelTurns                    AdWheelTurn[]
  assignments                     Assignment[]
  user                            User?
  messagingConnection             MessagingConnection?
  aiAgentConfigs                  AiAgentConfig[]
  channelInstances                ChannelInstance[]
  automationDispatches            AutomationDispatch[]
  leadNotes                       LeadNote[]
  attributedCrmAssignments        CrmLeadAssignment[]  @relation("CrmAssignmentAttributedSponsor")
  assignedCrmAssignments          CrmLeadAssignment[]  @relation("CrmAssignmentAssignedSponsor")
  acceptedCrmAssignments          CrmLeadAssignment[]  @relation("CrmAssignmentAcceptedSponsor")
  conversationOwnerCrmAssignments CrmLeadAssignment[]  @relation("CrmAssignmentConversationOwnerSponsor")
  actorCrmAssignmentEvents        CrmAssignmentEvent[]
  crmOutreachQueue                CrmOutreachQueue[]
  vanityShortLink                 SponsorVanityShortLink?
  commercialProfiles              CommercialProfile[]
}

model CommercialProfile {
  id               String    @id @default(uuid())
  workspaceId      String
  teamId           String    @unique
  sponsorId        String?
  vertical         String
  industry         String
  businessModel    String
  legacyNiche      String?
  presetVersion    String
  blueprintKey     String
  blueprintVersion String
  businessName     String
  mainProduct      String?
  averagePrice     String?
  salesMotion      String?
  country          String?
  phone            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team             Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sponsor          Sponsor?  @relation(fields: [sponsorId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([sponsorId])
}

model SponsorVanityShortLink {
  id               String    @id @default(uuid())
  workspaceId      String
  teamId           String
  sponsorId        String    @unique
  slug             String
  targetUrl        String
  shortCode        String    @unique
  shortUrl         String
  provider         String
  providerMetadata Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team             Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sponsor          Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([workspaceId, teamId])
  @@index([teamId, shortCode])
}

model AdWheel {
  id                  String               @id @default(uuid())
  teamId              String
  publicationId       String?
  status              AdWheelStatus
  name                String
  seatPrice           Int
  startDate           DateTime
  endDate             DateTime
  currentTurnPosition Int                  @default(1)
  sequenceVersion     Int                  @default(1)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  team                Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  publication         FunnelPublication?   @relation(fields: [publicationId], references: [id], onDelete: SetNull)
  participants        AdWheelParticipant[]
  turns               AdWheelTurn[]
  originLeads         Lead[]               @relation("LeadOriginAdWheel")
  originAssignments   Assignment[]         @relation("AssignmentOriginAdWheel")

  @@index([teamId, status])
  @@index([teamId, publicationId, status])
  @@index([teamId, startDate, endDate])
}

model AdWheelParticipant {
  adWheelId String
  sponsorId String
  seatCount Int      @default(1)
  joinedAt  DateTime @default(now())
  adWheel   AdWheel  @relation(fields: [adWheelId], references: [id], onDelete: Cascade)
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@id([adWheelId, sponsorId])
  @@index([sponsorId, joinedAt])
}

model AdWheelTurn {
  id              String   @id @default(uuid())
  adWheelId       String
  sponsorId       String
  position        Int
  sequenceVersion Int      @default(1)
  createdAt       DateTime @default(now())
  adWheel         AdWheel  @relation(fields: [adWheelId], references: [id], onDelete: Cascade)
  sponsor         Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([adWheelId, sequenceVersion, position])
  @@index([adWheelId, sequenceVersion, position])
  @@index([sponsorId, sequenceVersion])
}

model User {
  id                String           @id @default(uuid())
  workspaceId       String?
  teamId            String?
  sponsorId         String?          @unique
  fullName          String
  email             String           @unique
  passwordHash      String
  resetToken        String?          @unique
  resetTokenExpires DateTime?
  role              UserRole
  status            UserStatus
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  team              Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  sponsor           Sponsor?         @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  sessions          AuthSession[]
  leadNotes         LeadNote[]
  knowledgeAudits   KnowledgeAudit[]

  @@index([workspaceId, role])
  @@index([teamId, role])
}

model AuthSession {
  id               String   @id @default(uuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  lastSeenAt       DateTime @default(now())
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model MessagingConnection {
  id                             String                         @id @default(uuid())
  workspaceId                    String
  teamId                         String
  sponsorId                      String                         @unique
  provider                       MessagingProvider
  status                         MessagingConnectionStatus
  runtimeContextStatus           MessagingRuntimeContextStatus?
  runtimeContextTenantId         String?
  runtimeContextRegisteredAt     DateTime?
  runtimeContextReadyAt          DateTime?
  runtimeContextLastCheckedAt    DateTime?
  runtimeContextLastErrorAt      DateTime?
  runtimeContextLastErrorMessage String?
  externalInstanceId             String?                        @unique
  phone                          String?
  normalizedPhone                String?
  qrCodeData                     String?
  pairingCode                    String?
  pairingExpiresAt               DateTime?
  automationWebhookUrl           String?
  automationEnabled              Boolean                        @default(false)
  metadataJson                   Json?
  lastSyncedAt                   DateTime?
  lastConnectedAt                DateTime?
  lastDisconnectedAt             DateTime?
  lastErrorAt                    DateTime?
  lastErrorMessage               String?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  workspace                      Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                           Team                           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sponsor                        Sponsor                        @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  automationDispatches           AutomationDispatch[]

  @@index([workspaceId, provider, status])
  @@index([teamId, provider, status])
  @@index([workspaceId, runtimeContextStatus])
}

model AiAgentConfig {
  id            String   @id @default(uuid())
  tenantId      String
  memberId      String?
  basePrompt    String
  routeContexts Json?
  ctaPolicy     Json?
  aiPolicy      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Team     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member        Sponsor? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId])
  @@index([tenantId, isActive])
  @@index([memberId, isActive])
}

model ChannelInstance {
  id           String   @id @default(uuid())
  instanceName String   @unique
  tenantId     String
  memberId     String
  provider     String   @default("evolution")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Team     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member       Sponsor  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider])
  @@index([tenantId, memberId])
}

model KnowledgeAudit {
  id          String                  @id @default(uuid())
  tenantId    String
  userId      String?
  userName    String
  operation   KnowledgeAuditOperation
  documentId  String?
  fileName    String
  costKredits Decimal                 @default(0) @db.Decimal(18, 6)
  createdAt   DateTime                @default(now())
  tenant      Team                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

model Funnel {
  id                    String              @id @default(uuid())
  workspaceId           String
  name                  String
  description           String?
  code                  String
  thumbnailUrl          String?
  config                Json                @default("{}")
  status                FunnelStatus
  isTemplate            Boolean             @default(false)
  stages                String[]
  entrySources          LeadSourceChannel[]
  defaultTeamId         String?
  defaultRotationPoolId String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  defaultTeam           Team?               @relation("TeamDefaultFunnels", fields: [defaultTeamId], references: [id], onDelete: SetNull)
  defaultRotationPool   RotationPool?       @relation("PoolDefaultFunnels", fields: [defaultRotationPoolId], references: [id], onDelete: SetNull)
  funnelInstanceBridge  FunnelInstance?     @relation("FunnelInstanceFunnelLink")
  linkedDomains         Domain[]            @relation("DomainLinkedFunnel")
  leads                 Lead[]
  assignments           Assignment[]

  @@unique([workspaceId, code])
}

model Domain {
  id                         String                   @id @default(uuid())
  workspaceId                String
  teamId                     String
  linkedFunnelId             String?
  host                       String
  normalizedHost             String                   @unique
  status                     DomainStatus
  onboardingStatus           DomainOnboardingStatus   @default(draft)
  domainType                 DomainType
  isPrimary                  Boolean                  @default(false)
  canonicalHost              String?
  redirectToPrimary          Boolean                  @default(false)
  verificationStatus         DomainVerificationStatus @default(unverified)
  sslStatus                  DomainSslStatus          @default(unconfigured)
  verificationMethod         DomainVerificationMethod @default(none)
  cloudflareCustomHostnameId String?                  @unique
  cloudflareStatusJson       Json?
  dnsTarget                  String?
  lastCloudflareSyncAt       DateTime?
  activatedAt                DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  workspace                  Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                       Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  linkedFunnel               Funnel?                  @relation("DomainLinkedFunnel", fields: [linkedFunnelId], references: [id], onDelete: SetNull)
  funnelPublications         FunnelPublication[]
  funnelEvents               FunnelEvent[]

  @@index([teamId, isPrimary])
  @@index([teamId, onboardingStatus])
  @@index([teamId, linkedFunnelId])
}

model BlockDefinition {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  category    String
  schemaJson  Json
  exampleJson Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FunnelTemplate {
  id                       String               @id @default(uuid())
  workspaceId              String?
  name                     String
  description              String?
  code                     String               @unique
  status                   FunnelTemplateStatus
  version                  Int                  @default(1)
  funnelType               String
  blocksJson               Json
  mediaMap                 Json
  settingsJson             Json
  allowedOverridesJson     Json
  defaultHandoffStrategyId String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  workspace                Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  defaultHandoffStrategy   HandoffStrategy?     @relation("TemplateDefaultHandoffStrategy", fields: [defaultHandoffStrategyId], references: [id], onDelete: SetNull)
  funnelInstances          FunnelInstance[]
}

model FunnelInstance {
  id                   String               @id @default(uuid())
  workspaceId          String
  teamId               String
  templateId           String
  funnelId             String?              @unique
  name                 String
  code                 String
  thumbnailUrl         String?
  status               FunnelInstanceStatus
  structuralType       FunnelStructuralType @default(generic)
  conversionContract   Json                 @default("{}")
  rotationPoolId       String?
  trackingProfileId    String?
  handoffStrategyId    String?
  settingsJson         Json
  mediaMap             Json
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                 Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  template             FunnelTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  funnel               Funnel?              @relation("FunnelInstanceFunnelLink", fields: [funnelId], references: [id], onDelete: SetNull)
  rotationPool         RotationPool?        @relation(fields: [rotationPoolId], references: [id], onDelete: SetNull)
  trackingProfile      TrackingProfile?     @relation(fields: [trackingProfileId], references: [id], onDelete: SetNull)
  handoffStrategy      HandoffStrategy?     @relation("InstanceHandoffStrategy", fields: [handoffStrategyId], references: [id], onDelete: SetNull)
  steps                FunnelStep[]
  publications         FunnelPublication[]
  leads                Lead[]
  assignments          Assignment[]
  automationDispatches AutomationDispatch[]
  trackedLinks         TrackedLink[]
  funnelEvents         FunnelEvent[]

  @@unique([teamId, code])
  @@index([teamId, structuralType])
}

model FunnelStep {
  id               String              @id @default(uuid())
  workspaceId      String
  teamId           String
  funnelInstanceId String
  stepType         FunnelStepType
  slug             String
  position         Int
  isEntryStep      Boolean             @default(false)
  isConversionStep Boolean             @default(false)
  blocksJson       Json
  mediaMap         Json
  settingsJson     Json
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team             Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  funnelInstance   FunnelInstance      @relation(fields: [funnelInstanceId], references: [id], onDelete: Cascade)
  history          FunnelStepHistory[]
  trackedLinks     TrackedLink[]
  funnelEvents     FunnelEvent[]

  @@unique([funnelInstanceId, position])
  @@unique([funnelInstanceId, slug])
}

model FunnelStepHistory {
  id           String     @id @default(uuid())
  stepId       String
  blocksJson   Json
  settingsJson Json
  createdAt    DateTime   @default(now())
  createdBy    String?
  step         FunnelStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId, createdAt])
}

model FunnelPublication {
  id                   String                    @id @default(uuid())
  workspaceId          String
  teamId               String
  domainId             String
  funnelInstanceId     String
  trackingProfileId    String?
  handoffStrategyId    String?
  seoTitle             String?
  seoDescription       String?
  ogImageUrl           String?
  faviconUrl           String?
  manifestVersion      Int                       @default(1)
  runtimeHealthStatus  FunnelRuntimeHealthStatus @default(healthy)
  metaPixelId          String?
  tiktokPixelId        String?
  metaCapiToken        String?
  tiktokAccessToken    String?
  pathPrefix           String
  status               FunnelPublicationStatus
  isActive             Boolean                   @default(true)
  isPrimary            Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                 Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  domain               Domain                    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  funnelInstance       FunnelInstance            @relation(fields: [funnelInstanceId], references: [id], onDelete: Cascade)
  trackingProfile      TrackingProfile?          @relation(fields: [trackingProfileId], references: [id], onDelete: SetNull)
  handoffStrategy      HandoffStrategy?          @relation("PublicationHandoffStrategy", fields: [handoffStrategyId], references: [id], onDelete: SetNull)
  leads                Lead[]
  assignments          Assignment[]
  automationDispatches AutomationDispatch[]
  adWheels             AdWheel[]
  trackedLinks         TrackedLink[]
  funnelEvents         FunnelEvent[]

  @@unique([domainId, pathPrefix])
  @@index([domainId, status, pathPrefix])
  @@index([runtimeHealthStatus, status])
}

model TrackingProfile {
  id                      String                   @id @default(uuid())
  workspaceId             String
  teamId                  String
  name                    String
  provider                TrackingProvider
  status                  TrackingProfileStatus
  configJson              Json
  deduplicationMode       DeduplicationMode
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                    Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  funnelInstances         FunnelInstance[]
  funnelPublications      FunnelPublication[]
  conversionEventMappings ConversionEventMapping[]

  @@unique([teamId, name])
}

model ConversionEventMapping {
  id                   String          @id @default(uuid())
  trackingProfileId    String
  internalEventName    String
  providerEventName    String
  isBrowserSide        Boolean         @default(true)
  isServerSide         Boolean         @default(false)
  isCriticalConversion Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  trackingProfile      TrackingProfile @relation(fields: [trackingProfileId], references: [id], onDelete: Cascade)

  @@unique([trackingProfileId, internalEventName, providerEventName])
}

model HandoffStrategy {
  id                 String                @id @default(uuid())
  workspaceId        String
  teamId             String?
  name               String
  type               HandoffStrategyType
  status             HandoffStrategyStatus
  settingsJson       Json
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  workspace          Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team               Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  templateDefaults   FunnelTemplate[]      @relation("TemplateDefaultHandoffStrategy")
  funnelInstances    FunnelInstance[]      @relation("InstanceHandoffStrategy")
  funnelPublications FunnelPublication[]   @relation("PublicationHandoffStrategy")

  @@unique([workspaceId, teamId, name])
}

model RotationPool {
  id              String             @id @default(uuid())
  workspaceId     String
  teamId          String
  name            String
  status          RotationPoolStatus
  strategy        RotationStrategy
  isFallbackPool  Boolean
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members         RotationMember[]
  defaultFunnels  Funnel[]           @relation("PoolDefaultFunnels")
  funnelInstances FunnelInstance[]
  assignments     Assignment[]

  @@unique([workspaceId, name])
}

model RotationMember {
  id             String       @id @default(uuid())
  rotationPoolId String
  sponsorId      String
  position       Int
  weight         Int          @default(1)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rotationPool   RotationPool @relation(fields: [rotationPoolId], references: [id], onDelete: Cascade)
  sponsor        Sponsor      @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([rotationPoolId, sponsorId])
  @@unique([rotationPoolId, position])
}

model Visitor {
  id            String            @id @default(uuid())
  workspaceId   String
  anonymousId   String
  kind          VisitorKind
  status        VisitorStatus
  sourceChannel LeadSourceChannel
  firstSeenAt   DateTime
  lastSeenAt    DateTime
  utmSource     String?
  utmCampaign   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead          Lead?
  events        DomainEvent[]
  funnelEvents  FunnelEvent[]

  @@unique([workspaceId, anonymousId])
}

model Lead {
  id                   String                  @id @default(uuid())
  workspaceId          String
  funnelId             String
  funnelInstanceId     String?
  funnelPublicationId  String?
  trafficLayer         String?
  originAdWheelId      String?
  visitorId            String?                 @unique
  sourceChannel        LeadSourceChannel
  fullName             String?
  email                String?
  phone                String?
  companyName          String?
  status               LeadStatus
  qualificationGrade   LeadQualificationGrade?
  summaryText          String?
  nextActionLabel      String?
  followUpAt           DateTime?
  lastContactedAt      DateTime?
  lastQualifiedAt      DateTime?
  currentAssignmentId  String?                 @unique
  tags                 String[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  workspace            Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel               Funnel                  @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  funnelInstance       FunnelInstance?         @relation(fields: [funnelInstanceId], references: [id], onDelete: SetNull)
  funnelPublication    FunnelPublication?      @relation(fields: [funnelPublicationId], references: [id], onDelete: SetNull)
  originAdWheel        AdWheel?                @relation("LeadOriginAdWheel", fields: [originAdWheelId], references: [id], onDelete: SetNull)
  visitor              Visitor?                @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  assignments          Assignment[]            @relation("LeadAssignments")
  currentAssignment    Assignment?             @relation("CurrentLeadAssignment", fields: [currentAssignmentId], references: [id], onDelete: SetNull)
  events               DomainEvent[]
  automationDispatches AutomationDispatch[]
  notes                LeadNote[]
  trackedLinks         TrackedLink[]
  funnelEvents         FunnelEvent[]
  crmLeadAssignments   CrmLeadAssignment[]
  crmAssignmentEvents  CrmAssignmentEvent[]
  crmOutreachQueue     CrmOutreachQueue[]
}

model Assignment {
  id                   String               @id @default(uuid())
  ownershipKey         String?              @unique
  workspaceId          String
  leadId               String
  sponsorId            String
  teamId               String
  funnelId             String
  funnelInstanceId     String?
  funnelPublicationId  String?
  rotationPoolId       String?
  trafficLayer         String?
  originAdWheelId      String?
  status               AssignmentStatus
  reason               AssignmentReason
  assignedAt           DateTime
  acceptedAt           DateTime?
  resolvedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead                 Lead                 @relation("LeadAssignments", fields: [leadId], references: [id], onDelete: Cascade)
  sponsor              Sponsor              @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  team                 Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  funnel               Funnel               @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  funnelInstance       FunnelInstance?      @relation(fields: [funnelInstanceId], references: [id], onDelete: SetNull)
  funnelPublication    FunnelPublication?   @relation(fields: [funnelPublicationId], references: [id], onDelete: SetNull)
  rotationPool         RotationPool?        @relation(fields: [rotationPoolId], references: [id], onDelete: SetNull)
  originAdWheel        AdWheel?             @relation("AssignmentOriginAdWheel", fields: [originAdWheelId], references: [id], onDelete: SetNull)
  currentForLead       Lead?                @relation("CurrentLeadAssignment")
  events               DomainEvent[]
  automationDispatches AutomationDispatch[]
  trackedLinks         TrackedLink[]
  funnelEvents         FunnelEvent[]
}

model TrackedLink {
  id                  String            @id @default(uuid())
  workspaceId         String
  leadId              String
  assignmentId        String?
  ownershipKey        String?
  funnelPublicationId String
  funnelInstanceId    String
  funnelStepId        String
  stepKey             String
  appKey              String            @default("leadflow")
  action              String            @default("open_vsl")
  purpose             String            @default("vsl_followup")
  longUrl             String
  shortUrl            String?
  shortCode           String?
  shortLinkProvider   String
  ctxTokenHash        String            @unique
  status              TrackedLinkStatus @default(active)
  expiresAt           DateTime?
  clickCount          Int               @default(0)
  lastClickedAt       DateTime?
  createdBy           String?
  metadataJson        Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead                Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignment          Assignment?       @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  funnelPublication   FunnelPublication @relation(fields: [funnelPublicationId], references: [id], onDelete: Cascade)
  funnelInstance      FunnelInstance    @relation(fields: [funnelInstanceId], references: [id], onDelete: Cascade)
  funnelStep          FunnelStep        @relation(fields: [funnelStepId], references: [id], onDelete: Cascade)
  funnelEvents        FunnelEvent[]

  @@index([leadId, status])
  @@index([assignmentId, status])
  @@index([ownershipKey])
  @@index([shortCode])
  @@index([funnelPublicationId, funnelStepId, status])
  @@index([workspaceId, status, createdAt])
}

model FunnelEvent {
  id                  String   @id @default(uuid())
  eventId             String   @unique
  eventName           String
  eventVersion        String   @default("1.0")
  eventFamily         String
  source              String
  workspaceId         String
  teamId              String
  domainId            String?
  funnelPublicationId String?
  funnelInstanceId    String?
  funnelStepId        String?
  leadId              String?
  visitorId           String?
  assignmentId        String?
  trackedLinkId       String?
  actionLinkKey       String?
  trafficLayer        String
  attributionJson     Json?
  payloadJson         Json
  occurredAt          DateTime
  receivedAt          DateTime @default(now())
  correlationId       String?
  dedupeKey           String?  @unique
  createdAt           DateTime @default(now())
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  domain              Domain?            @relation(fields: [domainId], references: [id], onDelete: SetNull)
  funnelPublication   FunnelPublication? @relation(fields: [funnelPublicationId], references: [id], onDelete: SetNull)
  funnelInstance      FunnelInstance?    @relation(fields: [funnelInstanceId], references: [id], onDelete: SetNull)
  funnelStep          FunnelStep?        @relation(fields: [funnelStepId], references: [id], onDelete: SetNull)
  lead                Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  visitor             Visitor?           @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  assignment          Assignment?        @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  trackedLink         TrackedLink?       @relation(fields: [trackedLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, teamId, occurredAt])
  @@index([funnelPublicationId, eventName, occurredAt])
  @@index([leadId, occurredAt])
  @@index([visitorId, occurredAt])
  @@index([assignmentId, occurredAt])
  @@index([trackedLinkId, occurredAt])
  @@index([trafficLayer, eventName, receivedAt])
  @@index([eventFamily, eventName, occurredAt])
}

model AutomationDispatch {
  id                    String                   @id @default(uuid())
  workspaceId           String
  teamId                String
  sponsorId             String
  leadId                String
  assignmentId          String
  funnelInstanceId      String?
  funnelPublicationId   String?
  messagingConnectionId String?
  triggerType           String
  status                AutomationDispatchStatus
  targetWebhookUrl      String?
  payloadSnapshot       Json
  /// Payload maestro estructurado enviado al motor de IA (n8n/OpenAI)
  masterPayload         Json?
  /// Captura inmutable del contexto del lead en el momento de la creación
  contextSnapshot       Json?
  /// Reglas de cumplimiento (compliance) heredadas del Tenant en este instante
  compliancePolicy      Json?
  /// Reglas de Call to Action (CTA) heredadas del Tenant en este instante
  ctaPolicy             Json?
  responseSnapshot      Json?
  responseStatusCode    Int?
  errorCode             String?
  errorMessage          String?
  queuedAt              DateTime                 @default(now())
  dispatchedAt          DateTime?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  workspace             Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                  Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sponsor               Sponsor                  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  lead                  Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignment            Assignment               @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  funnelInstance        FunnelInstance?          @relation(fields: [funnelInstanceId], references: [id], onDelete: SetNull)
  funnelPublication     FunnelPublication?       @relation(fields: [funnelPublicationId], references: [id], onDelete: SetNull)
  messagingConnection   MessagingConnection?     @relation(fields: [messagingConnectionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([sponsorId, createdAt])
  @@index([assignmentId, createdAt])
  @@index([messagingConnectionId, createdAt])
}

model CrmLeadAssignment {
  id                         String              @id @default(uuid())
  workspaceId                String              @map("workspace_id")
  teamId                     String              @map("team_id")
  leadId                     String              @map("lead_id")
  attributedSponsorId        String?             @map("attributed_sponsor_id")
  assignedSponsorId          String?             @map("assigned_sponsor_id")
  acceptedBySponsorId        String?             @map("accepted_by_sponsor_id")
  conversationOwnerSponsorId String?             @map("conversation_owner_sponsor_id")
  assignmentStatus           CrmAssignmentStatus @map("assignment_status")
  assignmentSource           CrmAssignmentSource @map("assignment_source")
  ownershipLockedUntil       DateTime?           @map("ownership_locked_until")
  assignedAt                 DateTime?           @map("assigned_at")
  acceptedAt                 DateTime?           @map("accepted_at")
  lastConversationAt         DateTime?           @map("last_conversation_at")
  metadataJson               Json?               @map("metadata_json")
  createdAt                  DateTime            @default(now()) @map("created_at")
  updatedAt                  DateTime            @updatedAt @map("updated_at")
  workspace                  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                       Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lead                       Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  attributedSponsor          Sponsor?            @relation("CrmAssignmentAttributedSponsor", fields: [attributedSponsorId], references: [id], onDelete: SetNull)
  assignedSponsor            Sponsor?            @relation("CrmAssignmentAssignedSponsor", fields: [assignedSponsorId], references: [id], onDelete: SetNull)
  acceptedBySponsor          Sponsor?            @relation("CrmAssignmentAcceptedSponsor", fields: [acceptedBySponsorId], references: [id], onDelete: SetNull)
  conversationOwnerSponsor   Sponsor?            @relation("CrmAssignmentConversationOwnerSponsor", fields: [conversationOwnerSponsorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, teamId, assignmentStatus], map: "crm_lead_assignments_scope_status_idx")
  @@index([leadId, assignmentStatus], map: "crm_lead_assignments_lead_status_idx")
  @@index([assignedSponsorId, assignmentStatus], map: "crm_lead_assignments_assigned_sponsor_status_idx")
  @@index([conversationOwnerSponsorId, assignmentStatus], map: "crm_lead_assignments_conversation_owner_status_idx")
  @@index([ownershipLockedUntil], map: "crm_lead_assignments_lock_idx")
  @@map("crm_lead_assignments")
}

model CrmAssignmentEvent {
  id             String                 @id @default(uuid())
  workspaceId    String                 @map("workspace_id")
  teamId         String                 @map("team_id")
  leadId         String                 @map("lead_id")
  eventType      CrmAssignmentEventType @map("event_type")
  actorSponsorId String?                @map("actor_sponsor_id")
  source         CrmAssignmentSource
  metadataJson   Json?                  @map("metadata_json")
  createdAt      DateTime               @default(now()) @map("created_at")
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team           Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lead           Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorSponsor   Sponsor?               @relation(fields: [actorSponsorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, teamId, createdAt], map: "crm_assignment_events_scope_created_idx")
  @@index([leadId, createdAt], map: "crm_assignment_events_lead_created_idx")
  @@index([eventType, createdAt], map: "crm_assignment_events_type_created_idx")
  @@map("crm_assignment_events")
}

model CrmOutreachQueue {
  id                String                @id @default(uuid())
  workspaceId       String                @map("workspace_id")
  teamId            String                @map("team_id")
  leadId            String                @map("lead_id")
  sponsorId         String                @map("sponsor_id")
  intentType        CrmOutreachIntentType @map("intent_type")
  status            CrmOutreachStatus
  scheduledAt       DateTime?             @map("scheduled_at")
  randomizedDelayMs Int?                  @map("randomized_delay_ms")
  payloadJson       Json?                 @map("payload_json")
  retryCount        Int                   @default(0) @map("retry_count")
  lastAttemptAt     DateTime?             @map("last_attempt_at")
  nextRetryAt       DateTime?             @map("next_retry_at")
  failureReason     Json?                 @map("failure_reason")
  externalMissionId String?               @map("external_mission_id")
  externalHandoffStatus String?           @map("external_handoff_status")
  lastHandoffAt     DateTime?             @map("last_handoff_at")
  lastHandoffError  Json?                 @map("last_handoff_error")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team              Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lead              Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sponsor           Sponsor               @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([workspaceId, teamId, status, scheduledAt], map: "crm_outreach_queue_scope_status_schedule_idx")
  @@index([workspaceId, teamId, status, nextRetryAt], map: "crm_outreach_queue_scope_status_retry_idx")
  @@index([workspaceId, teamId, externalHandoffStatus], map: "crm_outreach_queue_scope_external_status_idx")
  @@index([externalMissionId], map: "crm_outreach_queue_external_mission_idx")
  @@index([sponsorId, status, createdAt], map: "crm_outreach_queue_sponsor_status_created_idx")
  @@index([leadId, intentType, status], map: "crm_outreach_queue_lead_intent_status_idx")
  @@map("crm_outreach_queue")
}

model LeadNote {
  id           String    @id @default(uuid())
  workspaceId  String
  teamId       String
  leadId       String
  sponsorId    String?
  authorUserId String
  authorRole   UserRole
  authorName   String
  body         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sponsor      Sponsor?  @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  authorUser   User      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([teamId, createdAt])
  @@index([authorUserId, createdAt])
}

model DomainEvent {
  id                  String             @id @default(uuid())
  workspaceId         String
  eventId             String
  aggregateType       EventAggregateType
  aggregateId         String
  eventName           String
  actorType           EventActorType
  payload             Json
  occurredAt          DateTime
  funnelInstanceId    String?
  funnelPublicationId String?
  funnelStepId        String?
  visitorId           String?
  leadId              String?
  assignmentId        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visitor             Visitor?           @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  lead                Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignment          Assignment?        @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([workspaceId, eventName, occurredAt])
  @@index([leadId, occurredAt])
  @@index([funnelPublicationId, occurredAt])
  @@index([funnelInstanceId, occurredAt])
  @@index([visitorId, occurredAt])
}
