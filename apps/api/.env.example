NODE_ENV=development
APP_ENV=staging
APP_BASE_DOMAIN=exitosos.com

API_NAME=leadflow-api
API_VERSION=0.2.0
API_HOST=0.0.0.0
API_PORT=3001
API_GLOBAL_PREFIX=v1
API_BASE_URL=https://api.exitosos.com
AUTH_COOKIE_NAME=leadflow_session
AUTH_SESSION_TTL_DAYS=7
DATABASE_URL=postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_SAAS_FALLBACK_ORIGIN=proxy-fallback.exitosos.com
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_REQUEST_TIMEOUT_MS=10000
EVOLUTION_API_INTERNAL_BASE_URL=http://evolution_evolution_api_v2:8080
EVOLUTION_API_PUBLIC_BASE_URL=
# Legacy compatibility fallback. Prefer EVOLUTION_API_INTERNAL_BASE_URL.
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_PREFIX=leadflow
EVOLUTION_WEBHOOK_EVENT=MESSAGES_UPSERT
MESSAGING_AUTOMATION_WEBHOOK_BASE_URL=
MESSAGING_AUTOMATION_WEBHOOK_TOKEN=
MESSAGING_AUTOMATION_DISPATCH_TIMEOUT_MS=4000
MESSAGING_AUTOMATION_DISPATCH_RETRIES=1
INCOMING_MESSAGING_WEBHOOK_SECRET=
EVOLUTION_REQUEST_TIMEOUT_MS=15000
EVOLUTION_REQUEST_RETRIES=2
EVOLUTION_QR_POLL_ATTEMPTS=5
EVOLUTION_QR_POLL_DELAY_MS=1000

SITE_URL=https://exitosos.com
MEMBERS_URL=https://members.exitosos.com
ADMIN_URL=https://admin.exitosos.com
CORS_ALLOWED_ORIGINS=https://exitosos.com,https://members.exitosos.com,https://admin.exitosos.com
