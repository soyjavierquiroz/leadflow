NODE_ENV=development
APP_ENV=staging
APP_BASE_DOMAIN=leadflow.kurukin.com

API_NAME=leadflow-api
API_VERSION=0.2.0
API_HOST=0.0.0.0
API_PORT=3001
API_GLOBAL_PREFIX=v1
API_BASE_URL=https://api.leadflow.kurukin.com
AUTH_COOKIE_NAME=leadflow_session
AUTH_SESSION_TTL_DAYS=7
DATABASE_URL=postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_SAAS_FALLBACK_ORIGIN=proxy-fallback.leadflow.kurukin.com
CLOUDFLARE_SAAS_CUSTOMER_CNAME_TARGET=customers.leadflow.kurukin.com
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_REQUEST_TIMEOUT_MS=10000
EVOLUTION_API_INTERNAL_BASE_URL=http://evolution_api_v2:8080
EVOLUTION_API_PUBLIC_BASE_URL=
# Legacy compatibility fallback. Prefer EVOLUTION_API_INTERNAL_BASE_URL.
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_PREFIX=leadflow
# Internal n8n webhook target for Evolution inbound events.
N8N_WEBHOOK_INTERNAL_BASE=http://n8n-v2_n8n_v2_webhook:5678/webhook
N8N_BASE_DOMAIN=kn8nv2.kurukin.com
N8N_WEBHOOK_SCHEME=https
N8N_WEBHOOK_BASE_PATH=/webhook
N8N_WEBHOOK_ID=7feee028-e25e-43a3-abac-1a0bf7b0ccf4
N8N_WEBHOOK_SECRET=
N8N_DISPATCHER_WEBHOOK_URL=http://n8n-v2_n8n_v2_webhook:5678/webhook/channels/dispatcher/lead-context-upsert
N8N_DISPATCHER_API_KEY=
N8N_OUTBOUND_WEBHOOK_URL=http://n8n-v2_n8n_v2_webhook:5678/webhook/channels/outbound/lead-rescue
RUNTIME_CONTEXT_CENTRAL_BASE_URL=
RUNTIME_CONTEXT_REGISTER_PATH=/register
RUNTIME_CONTEXT_RESOLVE_FULL_PATH=/resolve-full
RUNTIME_CONTEXT_CENTRAL_API_KEY=
RUNTIME_CONTEXT_REQUEST_TIMEOUT_MS=5000
RUNTIME_CONTEXT_RESOLVE_RETRIES=5
RUNTIME_CONTEXT_RESOLVE_DELAY_MS=1000
# Legacy/base URL for outbound automation dispatch from Leadflow to downstream flows.
MESSAGING_AUTOMATION_WEBHOOK_BASE_URL=http://leadflow_api:3001
# Dedicated base for n8n or other downstream automation dispatch.
N8N_AUTOMATION_WEBHOOK_BASE_URL=
MESSAGING_AUTOMATION_WEBHOOK_TOKEN=
MESSAGING_AUTOMATION_DISPATCH_TIMEOUT_MS=4000
MESSAGING_AUTOMATION_DISPATCH_RETRIES=1
EVOLUTION_REQUEST_TIMEOUT_MS=15000
EVOLUTION_REQUEST_RETRIES=2
EVOLUTION_QR_POLL_ATTEMPTS=5
EVOLUTION_QR_POLL_DELAY_MS=1000
MINIO_ENDPOINT=https://kminioback.kurukin.com
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_URL=https://cdn.kurukin.com

SITE_URL=https://leadflow.kurukin.com
MEMBERS_URL=https://leadflow.kurukin.com
ADMIN_URL=https://leadflow.kurukin.com
CORS_ALLOWED_ORIGINS=https://leadflow.kurukin.com,https://retodetransformacion.com,https://www.retodetransformacion.com
